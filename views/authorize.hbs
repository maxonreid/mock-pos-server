<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BridgePOS — Authorize Access</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #f1f5f9;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ── */
    .header {
      background: #1a2744;
      padding: 0 32px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .header-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #fff;
      font-weight: 700;
      font-size: 16px;
      letter-spacing: 0.3px;
    }
    .header-brand-icon {
      width: 28px;
      height: 28px;
      background: #f59e0b;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
    }
    .header-version {
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      font-weight: 400;
      letter-spacing: 0.5px;
    }
    .header-user {
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.07);
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    /* ── Main ── */
    .main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }

    /* ── Card ── */
    .card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 20px 40px -8px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 440px;
      overflow: hidden;
    }
    .card-top {
      padding: 32px 32px 24px;
      border-bottom: 1px solid #f1f5f9;
    }
    .connecting-row {
      display: flex;
      align-items: center;
      margin-bottom: 24px;
      justify-content: center;
    }
    .app-icon {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
      border: 1.5px solid #e2e8f0;
    }
    .app-icon img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 6px;
    }
    .app-icon-pos { background: #fff; font-size: 20px; }
    .app-icon-ob  { background: #0A0F1E; }
    .connector-line {
      flex: 1;
      height: 2px;
      background: repeating-linear-gradient(90deg, #cbd5e1 0px, #cbd5e1 6px, transparent 6px, transparent 12px);
      margin: 0 8px;
      position: relative;
    }
    .connector-arrow {
      position: absolute;
      right: -4px;
      top: -5px;
      color: #94a3b8;
      font-size: 12px;
    }
    .card-title {
      font-size: 18px;
      font-weight: 700;
      color: #0f172a;
      text-align: center;
      margin-bottom: 6px;
    }
    .card-subtitle {
      font-size: 13px;
      color: #64748b;
      text-align: center;
      line-height: 1.5;
    }
    .card-subtitle strong {
      color: #0f172a;
      font-weight: 600;
    }

    /* ── Permissions ── */
    .permissions {
      padding: 20px 32px;
      border-bottom: 1px solid #f1f5f9;
    }
    .permissions-title {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.5px;
      color: #94a3b8;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .perm-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .perm-row {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
    }
    .perm-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      flex-shrink: 0;
      font-weight: 700;
    }
    .perm-allow { background: #dcfce7; color: #16a34a; }
    .perm-deny  { background: #fee2e2; color: #dc2626; }
    .perm-text-allow { color: #1e293b; }
    .perm-text-deny  { color: #94a3b8; text-decoration: line-through; }

    /* ── Meta ── */
    .meta {
      padding: 16px 32px;
      background: #f8fafc;
      border-bottom: 1px solid #f1f5f9;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .meta-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      color: #94a3b8;
      text-transform: uppercase;
      margin-bottom: 3px;
    }
    .meta-value {
      font-size: 13px;
      color: #1e293b;
      font-weight: 500;
    }

    /* ── Actions ── */
    .actions {
      padding: 20px 32px 24px;
      display: flex;
      gap: 10px;
    }
    .btn {
      flex: 1;
      padding: 11px 16px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      font-family: inherit;
      transition: all 0.15s ease;
    }
    .btn-allow { background: #f59e0b; color: #fff; }
    .btn-allow:hover { background: #d97706; }
    .btn-deny  { background: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; }
    .btn-deny:hover { background: #e2e8f0; }

    /* ── Footer ── */
    .card-footer {
      text-align: center;
      padding: 16px;
      font-size: 11px;
      color: #94a3b8;
    }
    .card-footer a { color: #64748b; text-decoration: underline; }

    .page-footer {
      padding: 16px 32px;
      text-align: center;
      font-size: 11px;
      color: #94a3b8;
      border-top: 1px solid #e2e8f0;
      background: #fff;
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header-brand">
      <div class="header-brand-icon">🖨</div>
      MockPOS
      <span class="header-version">v0.2.1</span>
    </div>
    <div class="header-user">hello@MaxonTorres.com</div>
  </header>

  <main class="main">
    <div class="card">

      <div class="card-top">
        <div class="connecting-row">
          <div class="app-icon app-icon-ob">
            {{!-- OrderBridge logo image avatar circular --}}
            <img src="/public/orderbridge-logo.svg" alt="OrderBridge">
          </div>
          <div class="connector-line">
            <span class="connector-arrow">▶</span>
          </div>
          <div class="app-icon app-icon-pos">
            {{!-- This apps logo --}}
            <img src="/public/phing-kai-logo.png" alt="MockPOS">
          </div>
        </div>
        <h1 class="card-title">Authorize OrderBridge</h1>
        <p class="card-subtitle">
          <strong>OrderBridge</strong> is requesting access to your
          MockPOS account at <strong>Phing Kai Kitchen</strong>
        </p>
      </div>

      <div class="permissions">
        <div class="permissions-title">Permissions requested</div>
        <div class="perm-list">
          <div class="perm-row">
            <div class="perm-icon perm-allow">✓</div>
            <span class="perm-text-allow">Create new orders in your POS</span>
          </div>
          <div class="perm-row">
            <div class="perm-icon perm-allow">✓</div>
            <span class="perm-text-allow">Confirm order receipt and status</span>
          </div>
          <div class="perm-row">
            <div class="perm-icon perm-allow">✓</div>
            <span class="perm-text-allow">Read order history</span>
          </div>
          <div class="perm-row">
            <div class="perm-icon perm-deny">✗</div>
            <span class="perm-text-deny">Access customer payment data</span>
          </div>
          <div class="perm-row">
            <div class="perm-icon perm-deny">✗</div>
            <span class="perm-text-deny">Modify menu or pricing</span>
          </div>
          <div class="perm-row">
            <div class="perm-icon perm-deny">✗</div>
            <span class="perm-text-deny">Access staff or payroll data</span>
          </div>
        </div>
      </div>

      <div class="meta">
        <div>
          <div class="meta-label">Outlet</div>
          <div class="meta-value">Phing Kai Kitchen</div>
        </div>
        <div>
          <div class="meta-label">Account</div>
          <div class="meta-value">hello@MaxonTorres.com</div>
        </div>
        <div>
          <div class="meta-label">Application</div>
          <div class="meta-value">{{client_id}}</div>
        </div>
        <div>
          <div class="meta-label">Scope</div>
          <div class="meta-value">{{scope}}</div>
        </div>
      </div>

      <form method="POST" action="/oauth/authorize">
        <input type="hidden" name="redirect_uri" value="{{redirect_uri}}" />
        <input type="hidden" name="state" value="{{state}}" />
        <input type="hidden" name="client_id" value="{{client_id}}" />
        <div class="actions">
          <button type="submit" name="action" value="allow" class="btn btn-allow">
            Allow Access
          </button>
          <button type="submit" name="action" value="deny" class="btn btn-deny">
            Deny
          </button>
        </div>
      </form>

      <div class="card-footer">
        By allowing access you agree to the
        <a href="#">MockPOS API Terms of Service</a>
      </div>

    </div>
  </main>

  <div class="page-footer">
    MockPOS Simulation Platform &nbsp;·&nbsp; Designed & Built by <a href="https://www.maxontorres.com/en" target="_blank">Maxon Torres</a> 
  </div>

</body>
</html>
